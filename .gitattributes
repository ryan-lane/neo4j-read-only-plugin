# ── Default: normalise line endings to LF in the repo ─────────────────────────
* text=auto eol=lf

# ── Source files ──────────────────────────────────────────────────────────────
*.java      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.dockerfile text eol=lf
Dockerfile* text eol=lf

# ── Windows shell scripts keep CRLF ───────────────────────────────────────────
*.cmd  text eol=crlf
*.bat  text eol=crlf

# ── Binary files – never diff or merge ────────────────────────────────────────
*.jar   binary
*.class binary
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.zip   binary
*.gz    binary
